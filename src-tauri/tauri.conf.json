{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OpenWrap",
  "version": "0.1.0",
  "identifier": "app.openwrap.desktop",
  "build": {
    "beforeDevCommand": "npm run dev --workspace ui",
    "beforeBuildCommand": "cargo build -p openwrap-helper --release && npm run build --workspace ui",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../ui/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "OpenWrap",
        "width": 1180,
        "height": 780,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "app",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../target/release/openwrap-helper": "openwrap-helper-bundled"
    }
  }
}
